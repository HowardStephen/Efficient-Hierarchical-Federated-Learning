# ========================================
# Python compiled files
# ========================================
__pycache__/
*.py[cod]
*$py.class

# ========================================
# Virtual environments
# ========================================
venv/
.env/
.venv/
env/

# ========================================
# Jupyter Notebook checkpoints
# ========================================
.ipynb_checkpoints/

# ========================================
# Operating system files
# ========================================
.DS_Store
Thumbs.db

# ========================================
# IDE / Editor files
# ========================================
.vscode/
.idea/

# ========================================
# Log files
# ========================================
*.log

# ========================================
# Model files
# ========================================
*.pt
*.pth
*.ckpt
*.h5

# ========================================
# Dataset directory (do not include actual data)
# ========================================
data/*
!data/README.md

# ========================================
# Experimental results (only keep examples)
# ========================================
results/*
!results/README.md
!results/example/

# ========================================
# Temporary files
# ========================================
*.tmp
*.swp

# ========================================
# Visualization / Matplotlib cache
# ========================================
*.png
*.pdf
